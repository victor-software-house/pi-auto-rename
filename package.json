{
  "name": "pi-auto-rename",
  "version": "0.1.4",
  "description": "Auto-rename pi sessions with AI via a single /rename command",
  "license": "MIT",
  "author": "Victor Software House",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-software-house/pi-auto-rename.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "session",
    "rename"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "utils.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:biome && bun run lint:oxlint",
    "lint:biome": "biome check .",
    "lint:oxlint": "oxlint --import-plugin --type-aware --tsconfig=./tsconfig.json .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.63.1",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@mariozechner/pi-tui": "^0.63.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "12",
    "@semantic-release/npm": "^13.0.0",
    "@types/bun": "^1.3.11",
    "lefthook": "^1.13.6",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.0",
    "semantic-release": "^25.0.0",
    "typescript": "^6.0.2"
  }
}
